# ─────────────────────────────────────────────────────────────
# .env — Environment variables for the Flask auth backend
# NEVER commit this file to Git. Add it to .gitignore.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=12345
DB_NAME=steganography_db

# ── JWT ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING
JWT_EXPIRY_HOURS=24

# ── CORS ──────────────────────────────────────────────────────
# Your React app origin (no trailing slash)
FRONTEND_ORIGIN=http://localhost:5173

# ── Flask ─────────────────────────────────────────────────────
FLASK_DEBUG=false

# ── Optional: Redis for rate-limiter (more robust than memory) ─
# REDIS_URL=redis://localhost:6379
